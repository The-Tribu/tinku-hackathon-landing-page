{
  "name": "tinku-hackathon-landing-page",
  "version": "1.0.0",
  "type": "module",
  "description": "Landing page for Tinku — Ritual CreAItivo hackathon",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
