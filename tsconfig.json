{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@components/*": ["src/components/*"],
			"@layouts/*": ["src/layouts/*"],
			"@lib/*": ["src/lib/*"],
			"@styles/*": ["src/styles/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.astro", "src/**/*.svelte"],
	"exclude": ["node_modules", "dist"]
}
