---
interface Props {
	size?: "sm" | "md" | "lg";
	class?: string;
}

const { size = "sm", class: className = "" } = Astro.props;

const sizeClasses = {
	sm: "w-2 h-2",
	md: "w-3 h-3",
	lg: "w-4 h-4",
};
---

<span
	class:list={[
		"inline-block rotate-45 bg-brand shrink-0",
		sizeClasses[size],
		className,
	]}
	aria-hidden="true"
></span>
