---
import RitualFireGame from "@/components/ui/RitualFireGame.svelte";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<RitualFireGame
	client:load
	promptText={t("ritual.prompt")}
	completedTitle={t("ritual.completed.title")}
	completedSubtitle={t("ritual.completed.subtitle")}
	ctaText={t("ritual.cta")}
	replayLabel={t("ritual.replay")}
	skipLabel={t("ritual.skip")}
	closeLabel={t("ritual.close")}
	progressLabel={t("ritual.progress")}
	offeringNames={[
		t("ritual.offering.1"),
		t("ritual.offering.2"),
		t("ritual.offering.3"),
		t("ritual.offering.4"),
		t("ritual.offering.5"),
		t("ritual.offering.6"),
		t("ritual.offering.7"),
	]}
	rewardTitle={t("ritual.reward.title")}
	rewardIntro={t("ritual.reward.intro")}
	rewardStep1={t("ritual.reward.step1")}
	rewardStep2={t("ritual.reward.step2")}
	rewardFooter={t("ritual.reward.footer")}
	rewardConditionsLabel={t("ritual.reward.conditions")}
	rewardClaimedBadge={t("ritual.reward.claimedBadge")}
	rewardClaimedBadgeEmoji={t("ritual.reward.claimedBadgeEmoji")}
	rewardClaimedStatusPending={t("ritual.reward.claimedStatusPending")}
	rewardClaimedLegendPending={t("ritual.reward.claimedLegendPending")}
	rewardClaimedLegend={t("ritual.reward.claimedLegend")}
	rewardClaimedLegendPrefix={t("ritual.reward.claimedLegendPrefix")}
	rewardClaimedLegendTeamSeparator={t("ritual.reward.claimedLegendTeamSeparator")}
	rewardClaimedLegendSuffix={t("ritual.reward.claimedLegendSuffix")}
	rewardClaimedTba={t("ritual.reward.claimedTba")}
	claimStatus="claimed"
	claimedByTeam="SAMP KN"
	claimedByPeople={lang === "es" ? "Yeison Berancur, Sebastian Restrepo y Jorge A Henao" : "Yeison Berancur, Sebastian Restrepo, and Jorge A Henao"}
	rewardCta={t("ritual.reward.cta")}
	shareHeadline={t("ritual.share.headline")}
	shareSubline={t("ritual.share.subline")}
	shareSponsor={t("ritual.share.sponsor")}
	shareSponsorDetail={t("ritual.share.sponsorDetail")}
	shareTagline={t("ritual.share.tagline")}
	shareGenerating={t("ritual.share.generating")}
/>
