---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";
import { rules } from "@/lib/data/rules";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="rules" class="py-20 px-4">
	<div class="max-w-6xl mx-auto">
		<SectionLabel text={t("rules.label")} />
		<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-4">
			{t("rules.title")}
		</h2>
		<p class="text-text-secondary font-satoshi text-lg mb-12 max-w-2xl">
			{t("rules.description")}
		</p>

		<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
			{rules.map((rule) => (
				<div class="p-6 rounded-2xl bg-surface/60 border-t-[3px] border-brand/60">
					<span class="text-2xl mb-3 block">{rule.emoji}</span>
					<h3 class="text-lg font-inter font-bold text-text-primary mb-2">
						{t(rule.titleKey)}
					</h3>
					<p class="text-sm font-satoshi text-text-secondary">
						{t(rule.descriptionKey)}
					</p>
				</div>
			))}
		</div>
	</div>
</section>
