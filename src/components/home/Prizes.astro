---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const podiumPrizes = [
	{
		position: 2,
		emoji: "🥈",
		place: t("prizes.second.place"),
		value: t("prizes.second.value"),
		description: t("prizes.second.description"),
		order: 1, // Para orden visual en el grid
	},
	{
		position: 1,
		emoji: "🥇",
		place: t("prizes.first.place"),
		value: t("prizes.first.value"),
		description: t("prizes.first.description"),
		order: 2,
	},
	{
		position: 3,
		emoji: "🥉",
		place: t("prizes.third.place"),
		value: t("prizes.third.value"),
		description: t("prizes.third.description"),
		order: 3,
	},
];
---

<section id="prizes" class="py-20 px-4">
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-16">
			<SectionLabel text={t("prizes.label")} />
			<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-4">
				{t("prizes.title")}
			</h2>
		</div>

		<!-- Podium -->
		<div class="max-w-5xl mx-auto mb-12">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
				{podiumPrizes.map((prize) => (
					<div
						class:list={[
							"relative flex flex-col items-center text-center transition-transform hover:scale-105",
							{ "order-1": prize.position === 1 },
							{ "order-2": prize.position === 2 },
							{ "order-3": prize.position === 3 },
							{ "md:order-1": prize.order === 1 },
							{ "md:order-2": prize.order === 2 },
							{ "md:order-3": prize.order === 3 },
						]}
					>
						{/* Trophy/Medal Icon */}
						<div
							class:list={[
								"mb-4 flex items-center justify-center rounded-full",
								prize.position === 1
									? "w-20 h-20 text-5xl bg-gradient-to-br from-yellow-400/20 to-orange-400/20 border-2 border-yellow-400/40"
									: prize.position === 2
									? "w-16 h-16 text-4xl bg-gradient-to-br from-gray-300/20 to-gray-400/20 border-2 border-gray-300/40"
									: "w-14 h-14 text-3xl bg-gradient-to-br from-orange-600/20 to-orange-700/20 border-2 border-orange-600/40",
							]}
						>
							{prize.emoji}
						</div>

						{/* Card */}
						<div
							class:list={[
								"w-full rounded-2xl border-2 transition-all duration-300",
								prize.position === 1
									? "bg-surface/80 border-brand/60 shadow-[0_0_50px_var(--color-brand-glow)] p-8 md:mb-0"
									: prize.position === 2
									? "bg-surface/60 border-surface/60 p-6 md:mb-8"
									: "bg-surface/40 border-surface/40 p-6 md:mb-16",
							]}
						>
							{/* Place */}
							<p
								class:list={[
									"font-satoshi font-bold uppercase tracking-wider mb-2",
									prize.position === 1 ? "text-base text-brand" : "text-sm text-text-muted",
								]}
							>
								{prize.place}
							</p>

							{/* Value */}
							<p
								class:list={[
									"font-inter font-black mb-3 break-words",
									prize.position === 1
										? "text-2xl sm:text-3xl md:text-4xl text-brand"
										: prize.position === 2
										? "text-xl sm:text-2xl md:text-3xl text-text-primary"
										: "text-lg sm:text-xl md:text-2xl text-text-primary",
								]}
							>
								{prize.value}
							</p>

							{/* Description */}
							<p
								class:list={[
									"font-satoshi",
									prize.position === 1 ? "text-base text-text-secondary" : "text-sm text-text-muted",
								]}
							>
								{prize.description}
							</p>
						</div>
					</div>
				))}
			</div>
		</div>

		{/* Tech credits */}
		<div class="max-w-3xl mx-auto text-center">
			<div class="p-6 rounded-2xl bg-surface/30 border border-surface">
				<p class="font-inter font-bold text-text-primary mb-2">
					✨ {t("prizes.tech.title")}
				</p>
				<p class="text-sm font-satoshi text-text-secondary">
					{t("prizes.tech.description")}
				</p>
			</div>
		</div>
	</div>
</section>
