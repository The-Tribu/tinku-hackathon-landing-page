---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";
import { criteria } from "@/lib/data/criteria";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="evaluation" class="py-20 px-4">
	<div class="max-w-6xl mx-auto">
		<SectionLabel text={t("evaluation.label")} />
		<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-12">
			{t("evaluation.title")}
		</h2>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-0 rounded-2xl overflow-hidden bg-surface/40">
			{criteria.map((criterion, i) => (
				<div class:list={[
					"p-6 border-surface",
					i < criteria.length - 1 && "border-b lg:border-b-0 lg:border-r",
				]}>
					<span class="text-[44px] font-inter font-black text-brand/70 leading-none block mb-3">
						{String(criterion.number).padStart(2, "0")}
					</span>
					<h3 class="text-lg font-inter font-bold text-text-primary mb-2">
						{t(criterion.nameKey)}
					</h3>
					<p class="text-sm font-satoshi text-text-secondary">
						{t(criterion.descriptionKey)}
					</p>
				</div>
			))}
		</div>
	</div>
</section>
