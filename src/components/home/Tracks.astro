---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import TrackCarousel from "@/components/home/TrackCarousel.svelte";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";
import { tracks } from "@/lib/data/tracks";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const trackItems = tracks.map((track) => ({
	emoji: track.emoji,
	name: t(track.nameKey),
	description: t(track.descriptionKey),
	featured: track.featured ?? false,
}));
---

<section id="tracks" class="py-20 px-4">
	<div class="max-w-6xl mx-auto">
		<div class="mb-12 px-4 sm:px-0">
			<SectionLabel text={t("tracks.label")} />
			<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-4">
				{t("tracks.title")}
			</h2>
			<p class="text-text-secondary font-satoshi text-lg max-w-2xl">
				{t("tracks.description")}
			</p>
		</div>

		<TrackCarousel tracks={trackItems} client:visible />
	</div>
</section>
