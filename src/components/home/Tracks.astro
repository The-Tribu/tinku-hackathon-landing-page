---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";
import { tracks } from "@/lib/data/tracks";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="tracks" class="py-20 px-4">
	<div class="max-w-6xl mx-auto">
		<SectionLabel text={t("tracks.label")} />
		<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-4">
			{t("tracks.title")}
		</h2>
		<p class="text-text-secondary font-satoshi text-lg mb-12 max-w-2xl">
			{t("tracks.description")}
		</p>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
			{tracks.map((track, i) => (
				<div
					class:list={[
						"group p-6 rounded-2xl bg-surface/60 border border-transparent hover:border-brand/40 hover:shadow-[0_0_30px_var(--color-brand-glow)] hover:-translate-y-1 transition-all duration-200",
						i >= 3 && "sm:col-span-1 lg:col-auto",
					]}
				>
					<span class="text-3xl mb-3 block">{track.emoji}</span>
					<h3 class="text-lg font-inter font-bold text-text-primary mb-2">
						{t(track.nameKey)}
					</h3>
					<p class="text-sm font-satoshi text-text-secondary">
						{t(track.descriptionKey)}
					</p>
				</div>
			))}
		</div>
	</div>
</section>
