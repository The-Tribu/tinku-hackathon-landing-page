---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const scheduleDays = [
	{
		day: lang === "es" ? "Viernes 17 de abril" : "Friday, April 17",
		events: [
			{ time: "17:00", name: lang === "es" ? "Registro y acreditación" : "Registration and check-in", highlight: false },
			{ time: "18:00", name: lang === "es" ? "Ceremonia de apertura" : "Opening ceremony", highlight: true },
			{ time: "18:30", name: lang === "es" ? "Presentación de retos" : "Challenge presentation", highlight: true },
			{ time: "19:00", name: lang === "es" ? "¡Comienza el hacking!" : "Hacking begins!", highlight: true },
			{ time: "21:00", name: lang === "es" ? "Cena" : "Dinner", highlight: false },
			{ time: "23:00", name: lang === "es" ? "Cierre de la jornada" : "End of day", highlight: false },
		]
	},
	{
		day: lang === "es" ? "Sábado 18 de abril" : "Saturday, April 18",
		events: [
			{ time: "07:00", name: lang === "es" ? "Desayuno" : "Breakfast", highlight: false },
			{ time: "12:00", name: lang === "es" ? "Almuerzo" : "Lunch", highlight: false },
			{ time: "13:00", name: lang === "es" ? "Finaliza el hacking" : "Hacking ends", highlight: true },
			{ time: "13:00", name: lang === "es" ? "Hora límite de entrega" : "Submission deadline", highlight: true },
			{ time: "13:30", name: lang === "es" ? "Presentaciones (pitches)" : "Presentations (pitches)", highlight: true },
			{ time: "15:00", name: lang === "es" ? "Ceremonia de premiación" : "Awards ceremony", highlight: true },
			{ time: "21:00", name: lang === "es" ? "Fiesta de remate" : "Closing party", highlight: false },
		]
	}
];
---

<section id="schedule" class="py-20 px-4">
	<div class="max-w-3xl mx-auto">
		<SectionLabel text={t("schedule.label")} />
		<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-12">
			{t("schedule.title")}
		</h2>

		<div class="space-y-12">
			{scheduleDays.map((daySchedule, dayIndex) => (
				<div class="relative">
					{/* Day header */}
					<h3 class="text-2xl font-inter font-bold text-text-primary mb-6 flex items-center gap-3">
						<div class="w-2 h-2 rounded-full bg-brand animate-pulse"></div>
						{daySchedule.day}
					</h3>

					{/* Gradient timeline line */}
					<div
						class="absolute left-[19px] top-14 bottom-0 w-px"
						style="background: linear-gradient(to bottom, var(--color-surface), var(--color-brand), var(--color-surface));"
						aria-hidden="true"
					></div>

					<div class="space-y-6">
						{daySchedule.events.map((item) => (
							<div class="relative flex items-start gap-6 pl-12">
								{/* Diamond marker */}
								<div class="absolute left-[12px] top-1.5 w-[15px] h-[15px] rotate-45 border-2 border-brand bg-bg shrink-0" aria-hidden="true">
									{item.highlight && (
										<div class="absolute inset-[3px] bg-brand/60 rounded-sm"></div>
									)}
								</div>
								<div>
									<span class="font-mono text-sm text-brand font-bold">{item.time}</span>
									<p class:list={[
										"font-inter font-semibold text-text-primary",
										item.highlight ? "text-lg" : "text-base opacity-80",
									]}>
										{item.name}
									</p>
								</div>
							</div>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>
