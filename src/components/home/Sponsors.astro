---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";
import { sponsors, sponsorTiers } from "@/lib/data/sponsors";
import type { TranslationKey } from "@/lib/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tierLabelKeys: Record<string, TranslationKey> = {
	main: "sponsors.tier.main",
	technology: "sponsors.tier.technology",
	allies: "sponsors.tier.allies",
};

// Escalas de tamaño por tier
const tierStyles = {
	main: {
		logoHeight: "h-14",
		padding: "px-7 py-3.5",
		fontSize: "text-lg",
		borderWidth: "border-2",
	},
	technology: {
		logoHeight: "h-10",
		padding: "px-5 py-2.5",
		fontSize: "text-base",
		borderWidth: "border",
	},
	allies: {
		logoHeight: "h-8",
		padding: "px-4 py-2",
		fontSize: "text-sm",
		borderWidth: "border",
	},
};
---

<section id="sponsors" class="py-20 px-4">
	<div class="max-w-6xl mx-auto text-center">
		<SectionLabel text={t("sponsors.label")} />
		<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-12">
			{t("sponsors.title")}
		</h2>

		<div class="space-y-10">
			{sponsorTiers.map((tier) => {
				const tierSponsors = sponsors.filter((s) => s.tier === tier);
				if (tierSponsors.length === 0) return null;
				const styles = tierStyles[tier];
				return (
					<div>
						<p class="text-xs font-satoshi font-bold uppercase tracking-[0.2em] text-text-muted mb-4">
							{t(tierLabelKeys[tier]!)}
						</p>
						<div class="flex flex-wrap items-center justify-center gap-3">
							{tierSponsors.map((sponsor) => (
								<span class:list={[
									styles.padding,
									styles.fontSize,
									styles.borderWidth,
									"rounded-lg bg-surface/50 border-surface font-inter font-bold text-text-secondary hover:text-text-primary hover:border-brand/20 transition-all duration-200 inline-flex items-center justify-center"
								]}>
									{sponsor.logo ? (
										<img
											src={sponsor.logo}
											alt={sponsor.name}
											class:list={[styles.logoHeight, "w-auto object-contain max-w-[200px]"]}
										/>
									) : (
										sponsor.name
									)}
								</span>
							))}
						</div>
					</div>
				);
			})}
		</div>
	</div>
</section>
