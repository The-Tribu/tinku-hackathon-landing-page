---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";
import { sponsors, sponsorTiers } from "@/lib/data/sponsors";
import type { TranslationKey } from "@/lib/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tierLabelKeys: Record<string, TranslationKey> = {
	main: "sponsors.tier.main",
	technology: "sponsors.tier.technology",
	allies: "sponsors.tier.allies",
};

// Escalas de tamaño por tier proporcionales a organizadores
// Organizadores y Main: 100%
// Technology: 70%
// Allies: 40%
//
// Desktop - Base: 100% = h-44 (176px) × max-w-[400px]
// Main: 100% → h-44 × max-w-[400px]
// Technology: 70% → h-32 (128px) × max-w-[280px]
// Allies: 40% → h-18 (72px) × max-w-[160px]
//
// Mobile - Base: 100% = h-32 (128px) × max-w-[280px]
// Main: 100% → h-32 × max-w-[280px]
// Technology: 70% → h-24 (96px) × max-w-[200px]
// Allies: 40% → h-12 (48px) × max-w-[120px]
const tierStyles = {
	main: {
		logoHeight: "h-32 sm:h-44",
		maxWidth: "max-w-[280px] sm:max-w-[400px]",
		padding: "px-6 py-3 sm:px-8 sm:py-4",
		fontSize: "text-base sm:text-lg",
		borderWidth: "border sm:border-2",
	},
	technology: {
		logoHeight: "h-24 sm:h-32",
		maxWidth: "max-w-[140px] sm:max-w-[180px]",
		padding: "px-4 py-2 sm:px-5 sm:py-2.5",
		fontSize: "text-sm sm:text-base",
		borderWidth: "border",
	},
	allies: {
		logoHeight: "h-12 sm:h-18",
		maxWidth: "max-w-[120px] sm:max-w-[160px]",
		padding: "px-3 py-1.5 sm:px-4 sm:py-2",
		fontSize: "text-xs sm:text-sm",
		borderWidth: "border",
	},
};
---

<section id="sponsors" class="py-20 px-4">
	<div class="max-w-6xl mx-auto text-center">
		<SectionLabel text={t("sponsors.label")} />
		<h2 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-12">
			{t("sponsors.title")}
		</h2>

		<div class="space-y-10">
			{sponsorTiers.map((tier) => {
				const tierSponsors = sponsors.filter((s) => s.tier === tier);
				if (tierSponsors.length === 0) return null;
				const styles = tierStyles[tier];
				return (
					<div>
						<p class="text-xs font-satoshi font-bold uppercase tracking-[0.2em] text-text-muted mb-4">
							{t(tierLabelKeys[tier]!)}
						</p>
						<div class="flex flex-wrap items-center justify-center gap-3">
							{tierSponsors.map((sponsor) => {
								const content = sponsor.logo ? (
									<img
										src={sponsor.logo}
										alt={sponsor.name}
										class:list={[styles.logoHeight, styles.maxWidth, "w-auto object-contain flex-shrink-0"]}
									/>
								) : (
									sponsor.name
								);

								const baseClasses = [
									styles.padding,
									styles.fontSize,
									styles.borderWidth,
									"rounded-lg bg-surface/50 border-surface font-inter font-bold text-text-secondary hover:text-text-primary hover:border-brand/20 transition-all duration-200 inline-flex items-center justify-center",
									sponsor.logo ? "min-h-fit" : ""
								];

								return sponsor.url ? (
									<a
										href={sponsor.url}
										target="_blank"
										rel="noopener noreferrer"
										class:list={[...baseClasses, "hover:scale-105 no-underline"]}
										title={sponsor.name}
									>
										{content}
									</a>
								) : (
									<span class:list={baseClasses}>
										{content}
									</span>
								);
							})}
						</div>
					</div>
				);
			})}
		</div>
	</div>
</section>
