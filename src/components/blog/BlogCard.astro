---
interface Props {
	title: string;
	date: Date;
	excerpt: string;
	tags: string[];
	href: string;
}

const { title, date, excerpt, tags, href } = Astro.props;

const formattedDate = date.toLocaleDateString("es-CO", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<a href={href} class="group block p-6 rounded-2xl bg-surface/40 border border-surface hover:border-brand/30 hover:shadow-[0_0_20px_var(--color-brand-glow)] transition-all duration-200">
	<time class="text-xs font-mono text-text-muted">{formattedDate}</time>
	<h3 class="text-lg font-inter font-bold text-text-primary mt-2 mb-3 group-hover:text-brand transition-colors">
		{title}
	</h3>
	<p class="text-sm font-satoshi text-text-secondary line-clamp-3 mb-4">
		{excerpt}
	</p>
	<div class="flex flex-wrap gap-2">
		{tags.map((tag) => (
			<span class="px-2.5 py-1 rounded-md bg-brand/10 text-brand text-xs font-inter font-medium">
				{tag}
			</span>
		))}
	</div>
</a>
