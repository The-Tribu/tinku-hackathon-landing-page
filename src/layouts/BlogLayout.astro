---
import MainLayout from "./MainLayout.astro";
import Footer from "@/components/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "@/lib/i18n";

interface Props {
	title: string;
	date: Date;
	tags: string[];
	author?: string;
}

const { title, date, tags, author } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const formattedDate = date.toLocaleDateString(lang === "es" ? "es-CO" : "en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const blogListHref = lang === "en" ? "/en/blog/" : "/blog/";
---

<MainLayout title={`${title} | Tinku Blog`}>
	<article class="max-w-3xl mx-auto px-4 py-20">
		<a href={blogListHref} class="inline-block text-brand font-inter font-medium text-sm hover:underline mb-8">
			{t("blog.backToList")}
		</a>

		<header class="mb-10">
			<div class="flex flex-wrap gap-2 mb-4">
				{tags.map((tag) => (
					<span class="px-2.5 py-1 rounded-md bg-brand/10 text-brand text-xs font-inter font-medium">
						{tag}
					</span>
				))}
			</div>
			<h1 class="text-3xl sm:text-4xl font-inter font-black text-text-primary mb-4">
				{title}
			</h1>
			<div class="flex items-center gap-4 text-sm text-text-muted font-satoshi">
				<time>{formattedDate}</time>
				{author && <span>· {author}</span>}
			</div>
		</header>

		<div class="prose prose-invert prose-brand max-w-none font-satoshi text-text-secondary leading-relaxed [&_h2]:font-inter [&_h2]:text-text-primary [&_h2]:font-bold [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:font-inter [&_h3]:text-text-primary [&_h3]:font-bold [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3 [&_strong]:text-text-primary [&_a]:text-brand [&_a:hover]:underline [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-text-secondary [&_p]:mb-4">
			<slot />
		</div>
	</article>
	<Footer slot="footer" />
</MainLayout>
